# Environment
ENVIRONMENT=development
TESTING=false
API_V1_STR=/api/v1

# Security
# Run: openssl rand -hex 32
JWT_SECRET_KEY=placeholder_jwt_secret_key_change_me_in_production
JWT_REFRESH_SECRET_KEY=placeholder_jwt_refresh_secret_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_SECRET_TOKEN=your_telegram_webhook_secret_token

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=imkon_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password@localhost:5432/imkon_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=noreply@example.com

# Timezone (Asia/Dushanbe, UTC+5)
TIMEZONE=Asia/Dushanbe

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]
